# Steps
# Create venv (once per project)
python -m venv .venv
# Activate (every new terminal)
.venv\Scripts\activate
# Install packages
pip install <package>
# Run the script
python myscript.py
# Save dependencies
pip freeze > requirements.txt
# Deactivate when done
deactivate
# Recreate environment
pip install -r requirements.txt

# Allow scripts in powershell:
Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope CurrentUser

# Activate virutual environment:
.venv\Scripts\activate

# ALTERNATIVE USE CMD
.venv\Scripts\activate.bat

# For putting on another machine (Copy all except the .venv)
Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope CurrentUser
cd C:\wherever\you\put\the\project

python -m venv .venv
.venv\Scripts\activate

pip install -r requirements.txt